{
  "name": "server",
  "version": "1.0.0",
  "main": "index.ts",
  "license": "MIT",
  "scripts": {
    "build": "tsc",
    "start": "tsc & node .",
    "dev": "tsc -w & nodemon .",
    "autostart": "tsc & nodemon ."
  },
  "dependencies": {
    "@novu/node": "^0.4.0-alpha.12",
    "@types/mongoose": "^5.11.97",
    "bcrypt": "^5.0.1",
    "bluebird": "^3.7.2",
    "celebrate": "^15.0.1",
    "compression": "^1.7.4",
    "dotenv": "^16.0.0",
    "eslint-config-prettier": "^8.5.0",
    "event-dispatch": "^0.4.1",
    "express": "^4.17.3",
    "express-mongo-sanitize": "^2.2.0",
    "express-session": "^1.17.2",
    "geoip-lite": "^1.4.5",
    "helmet": "^5.0.2",
    "http-proxy-middleware": "^2.0.4",
    "jest": "^28.1.0",
    "joi": "^17.6.0",
    "memory-cache": "^0.2.0",
    "module-alias": "^2.2.2",
    "mongodb": "^4.6.0",
    "mongoose": "^6.3.3",
    "morgan": "^1.10.0",
    "multer": "^1.4.4",
    "passport-jwt": "^4.0.0",
    "path": "^0.12.7",
    "prettier": "^2.6.2",
    "reflect-metadata": "^0.1.13",
    "request": "^2.88.2",
    "request-ip": "^2.1.3",
    "short-unique-id": "^4.4.4",
    "typedi": "^0.10.0",
    "validator": "^13.7.0",
    "winston": "^3.7.2",
    "xss-clean": "^0.1.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.13",
    "@types/node": "^17.0.25",
    "@typescript-eslint/eslint-plugin": "^5.23.0",
    "@typescript-eslint/parser": "^5.23.0",
    "eslint": "^8.15.0",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-plugin-import": "^2.26.0",
    "eslint-plugin-security": "^1.5.0",
    "nodemon": "^2.0.15",
    "typescript": "^4.6.4"
  },
  "eslintConfig": {
    "env": {
      "commonjs": true,
      "es2021": true,
      "node": true
    },
    "extends": [
      "airbnb-base"
    ],
    "parser": "@typescript-eslint/parser",
    "parserOptions": {
      "ecmaVersion": "latest"
    },
    "plugins": [
      "@typescript-eslint",
      "plugin:security/recommended"
    ],
    "rules": {
      "brace-style": [
        "error",
        "stroustrup"
      ],
      "comma-dangle": [
        "error",
        "never"
      ],
      "no-unused-vars": [
        "warn"
      ],
      "no-var": [
        "off"
      ],
      "one-var": [
        "off"
      ]
    }
  }
}
